",\"width\":120,\"height\":90},\"medium\":{\"url\":\"https://i.ytimg.com/vi/sB6cocqLXNw/mqdefault.jpg\",\"width\":320,\"height\":180},\"high\":{\"url\":\"https://i.ytimg.com/vi/sB6cocqLXNw/hqdefault.jpg\",\"width\":480,\"height\":360},\"standard\":{\"url\":\"https://i.ytimg.com/vi/sB6cocqLXNw/sddefault.jpg\",\"width\":640,\"height\":480},\"maxres\":{\"url\":\"https://i.ytimg.com/vi/sB6cocqLXNw/maxresdefault.jpg\",\"width\":1280,\"height\":720}},\"channelTitle\":\"Solana\",\"playlistId\":\"PLilwLeBwGuK6p3pB-vUQf1TjkX48j0Af-\",\"position\":4,\"resourceId\":{\"kind\":\"youtube#video\",\"videoId\":\"sB6cocqLXNw\"},\"videoOwnerChannelTitle\":\"Solana\",\"videoOwnerChannelId\":\"UC9AdQPUe4BdVJ8M9X7wxHUA\"},\"contentDetails\":{\"videoId\":\"sB6cocqLXNw\",\"videoPublishedAt\":\"2025-12-27T20:13:30Z\"}}],\"news\":[{\"id\":\"case-study-takenos\",\"published\":\"17 Mar 2026\",\"title\":\"Reimagining Global Payroll with Takenos\",\"tags\":[\"Case Studies\"],\"categories\":[\"Payments\"],\"url\":\"/news/case-study-takenos\",\"description\":\"Streamlining Cross-Border Payments in Latin America and Beyond\",\"heroImage\":\"/uploads/posts/case-study-takenos/hero.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"case-study-takenos\"},{\"id\":\"webinar-recap-corporate-treasury-onchain\",\"published\":\"17 Mar 2026\",\"title\":\"Webinar Recap: Corporate Treasury Onchain — 24/7 Global Liquidity\",\"tags\":[\"Payments\",\"Finance\",\"Ecosystem\"],\"categories\":[\"Payments\"],\"url\":\"/news/webinar-recap-corporate-treasury-onchain\",\"description\":\"Discover how global enterprises are moving corporate treasury onchain. Learn how Solana and Fireblocks enable 24/7 liquidity, instant global payouts, and yield generation using stablecoins.\",\"heroImage\":\"/uploads/posts/webinar-recap-corporate-treasury-onchain/heroImage.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"webinar-recap-corporate-treasury-onchain\"},{\"id\":\"state-of-solana-february-2026\",\"published\":\"05 Mar 2026\",\"title\":\"Solana Ecosystem Report: February 2026\",\"tags\":[\"Featured\",\"Reports\",\"Ecosystem\",\"Defi\",\"AI\",\"Finance\",\"Solana\"],\"categories\":[\"Ecosystem\"],\"url\":\"/news/state-of-solana-february-2026\",\"description\":\"February 2026 saw Solana's network-level metrics diverge from broader market contraction, with SOL-denominated TVL hitting all-time highs, RWA market cap reaching $1.71B, and stablecoin transactions surpassing $650B.\",\"heroImage\":\"/uploads/builder/state-of-solana-february-2026/feb-report.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"state-of-solana-february-2026\"},{\"id\":\"how-cards-became-the-trojan-horse-for-stablecoin-adoption\",\"published\":\"02 Mar 2026\",\"title\":\"How Cards Became the Trojan Horse for Stablecoin Adoption\",\"tags\":[\"Payments\",\"Finance\",\"Stable Coin\",\"Business\",\"Blockchain\"],\"categories\":[\"Finance\",\"Payments\"],\"url\":\"/news/how-cards-became-the-trojan-horse-for-stablecoin-adoption\",\"description\":\"Rain's Nick Pinto explains why stablecoin-backed cards are scaling quickly, how Rain settles with Visa in USDC, and why cards may be the distribution layer that brings digital dollars into everyday commerce.\",\"heroImage\":\"/uploads/posts/how-cards-became-the-trojan-horse-for-stablecoin-adoption/hero.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"how-cards-became-the-trojan-horse-for-stablecoin-adoption\"},{\"id\":\"payments-on-solana-production-ready-ecosystem-webinar\",\"published\":\"26 Feb 2026\",\"title\":\"Webinar Recap: Payments on Solana - A Production-Ready Ecosystem\",\"tags\":[\"Payments\",\"Finance\",\"Solana Pay\",\"Partner\",\"Ecosystem\"],\"categories\":[\"Payments\"],\"url\":\"/news/payments-on-solana-production-ready-ecosystem-webinar\",\"description\":\"Recap of the \\\"Payments on Solana\\\" webinar featuring Sheraz Shere and Ilan Gitter, covering why Visa, PayPal, and Worldpay are building on Solana across treasury management, remittances, neobanking, payouts, and merchant settlement.\",\"heroImage\":\"/uploads/builder/payments-on-solana-production-ready-ecosystem-webinar/payments-webinar.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"payments-on-solana-production-ready-ecosystem-webinar\"},{\"id\":\"matrixdock-xaum-launch\",\"published\":\"10 Feb 2026\",\"title\":\"Matrixdock Brings XAUm to Solana, Expanding Institutional-Grade Tokenized Gold Access\",\"tags\":[\"Defi\",\"Finance\",\"Blockchain\",\"Partner\",\"Solana Foundation\"],\"categories\":[\"DeFi\",\"Finance\"],\"url\":\"/news/matrixdock-xaum-launch\",\"description\":\"Matrixdock deploys XAUm, Asia's largest tokenized gold product, on Solana, enabling institutional-grade tokenized gold with near-instant settlement and DeFi integration.\",\"heroImage\":\"/uploads/builder/matrixdock-xaum-launch/matrixdock.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"matrixdock-xaum-launch\"},{\"id\":\"solana-network-upgrades\",\"published\":\"03 Feb 2026\",\"title\":\"Solana Network Upgrades\",\"tags\":[\"Announcements\"],\"categories\":[\"Finance\",\"Upgrades\"],\"url\":\"/news/solana-network-upgrades\",\"description\":\"A regularly-updated page giving the status of upgrades to the Solana network: Alpenglow, 100M CUs, SIMD 123, and more.\",\"heroImage\":\"/uploads/posts/solana-network-upgrades/ec9179222f514efd84eb1643f68f42b3.png\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"solana-network-upgrades\"},{\"id\":\"wisdomtree-tokenization-solana\",\"published\":\"28 Jan 2026\",\"title\":\"WisdomTree Expands Tokenization Ecosystem to Solana\",\"tags\":[\"Announcements\",\"Defi\",\"Ecosystem\",\"Finance\",\"Token\",\"Partner\"],\"categories\":[\"Finance\",\"Institutions\"],\"url\":\"/news/wisdomtree-tokenization-solana\",\"description\":\"Today, WisdomTree brings its full suite of regulated tokenized funds to Solana. Both institutional and retail investors can now access money market, equities, fixed income, alternatives, and asset allocation via WisdomTree Connect and WisdomTree Prime.\",\"heroImage\":\"/uploads/posts/wisdomtree-tokenization-solana/wisdom-tree.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"wisdomtree-tokenization-solana\"},{\"id\":\"solana-foundation-delegation-program-case-study\",\"published\":\"26 Jan 2026\",\"title\":\"The Solana Foundation Delegation Program\",\"tags\":[\"Solana Foundation\",\"Decentralization\",\"Reports\",\"Featured\"],\"categories\":[\"Ecosystem\"],\"url\":\"/news/solana-foundation-delegation-program-case-study\",\"description\":\"A Case Study on Validator Bootstrapping, Incentive Design, and Exit\",\"heroImage\":\"/uploads/posts/sfdp-monitoring/solana-sfdp.webp\",\"author\":{\"name\":\"Waddah Aldrobi\",\"avatar\":\"/uploads/authors/waddah-aldrobi.jpeg\"},\"cursor\":\"solana-foundation-delegation-program-case-study\"},{\"id\":\"ondo-global-markets-tokenized-stocks-etfs-solana\",\"published\":\"21 Jan 2026\",\"title\":\"Ondo Global Markets: Access 200+ Tokenized U.S. Stocks and ETFs on Solana\",\"tags\":[\"Defi\",\"Finance\",\"Ecosystem\",\"Partner\"],\"categories\":[\"DeFi\"],\"url\":\"/news/ondo-global-markets-tokenized-stocks-etfs-solana\",\"description\":\"Ondo Global Markets expands to Solana, offering over 200 tokenized U.S. stocks and ETFs onchain, becoming the largest real-world asset issuer on the network.\",\"heroImage\":\"/uploads/builder/ondo-global-markets-tokenized-stocks-etfs-solana/solana-ondo.webp\",\"author\":{\"name\":\"Solana Foundation\",\"avatar\":\"/uploads/authors/solanaLogoMark.svg\"},\"cursor\":\"ondo-global-markets-tokenized-stocks-etfs-solana\"}]}]\n"])</script></body></html>